# Локальная разработка. Для прода см. deploy/env.worker.example (+ ENV=production).
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxx.supabase.co:5432/postgres
# Имена переменных должны совпадать с app/config.py:
WORKER_SECRET=replace-me-long-random-string
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gsa.json
# Шифрование ключей маркетплейсов (в dev можно пусто → ключи в открытом виде):
SECRET_ENCRYPTION_KEY=
# Нужен только при ENV=production:
TELEGRAM_WEBHOOK_SECRET=
