{
  "name": "veloseller",
  "version": "0.1.0",
  "private": true,
  "description": "Veloseller — inventory intelligence for ecommerce sellers",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "npm run dev -w @veloseller/web",
    "build:web": "npm run build -w @veloseller/web",
    "lint:web": "npm run lint -w @veloseller/web",
    "worker:dev": "cd apps/worker && uvicorn app.main:app --reload --port 8001",
    "worker:test": "cd apps/worker && pytest -v"
  },
  "engines": {
    "node": ">=20"
  }
}
