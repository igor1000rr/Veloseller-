{
  "name": "veloseller",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:web": "pnpm --filter @veloseller/web dev",
    "build:web": "pnpm --filter @veloseller/web build",
    "worker:dev": "cd apps/worker && uvicorn app.main:app --reload --port 8001",
    "worker:test": "cd apps/worker && pytest -v"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {"node": ">=20"}
}
