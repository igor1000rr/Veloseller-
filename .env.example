# ============================================================================
# Supabase Cloud (https://supabase.com/dashboard → Project Settings → API)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role — только server-side / worker. Никогда не светить в браузер.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Прямое подключение к Postgres (опционально, для psql/Prisma/бэкапов).
# Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:<password>@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres

# ============================================================================
# Worker (FastAPI)
# ============================================================================
WORKER_URL=http://localhost:8001
# Общий secret для аутентификации Web → Worker. Длинная случайная строка.
WORKER_SECRET=replace-me-long-random-string

# ============================================================================
# Google Sheets (один service account на всех селлеров)
# ============================================================================
# Селлер шарит свою таблицу этому email read-only.
# Положить JSON в apps/worker/secrets/gsa.json и НЕ коммитить.
GOOGLE_APPLICATION_CREDENTIALS=./apps/worker/secrets/gsa.json

# ============================================================================
# Шифрование marketplace ключей (Ozon api_key, WB token, etc.)
# Генерация: openssl rand -base64 32  ИЛИ  openssl rand -hex 32
# Если не задан — ключи хранятся в БД plain (только для dev!)
# ============================================================================
SECRET_ENCRYPTION_KEY=

# ============================================================================
# Email уведомления через Resend (https://resend.com)
# Если RESEND_API_KEY не задан — daily digest job ничего не шлёт
# ============================================================================
RESEND_API_KEY=
RESEND_FROM=Veloseller <noreply@yourdomain.com>

# ============================================================================
# Админ панель — список email через запятую
# Только эти юзеры увидят /admin (после логина обычным образом)
# ============================================================================
ADMIN_EMAILS=igor1000rr@gmail.com,you@example.com

# ============================================================================
# Telegram бот для уведомлений (опционально)
# Создать бота через @BotFather в Telegram, получить токен
# ============================================================================
TELEGRAM_BOT_TOKEN=

# Telegram bot username (для deeplink-ссылки t.me/<bot>?start=<seller_id>)
# Без @, например: VelosellerBot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# ============================================================================
# Stripe billing
# Получить ключи: https://dashboard.stripe.com/test/apikeys
# Webhook secret: https://dashboard.stripe.com/test/webhooks (после установки)
# Price IDs создаются в https://dashboard.stripe.com/test/products
# ============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
