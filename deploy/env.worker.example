# Veloseller worker (.env) — СКОПИРОВАТЬ в /opt/veloseller/apps/worker/.env

# Прод-режим: включает fail-fast проверку критичных env в app/config.py
ENV=production

# Supabase
# Прод (.ru) — self-hosted: SUPABASE_URL=https://api.veloseller.ru
# (или http://127.0.0.1:8000, если worker на том же VPS, что и стек Supabase).
# ИМЯ важно: worker читает SUPABASE_SERVICE_ROLE_KEY (не SUPABASE_SERVICE_KEY).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__service_role_key__

# Worker auth (тот же что в web .env.production)
WORKER_SECRET=__сгенерить__

# Encryption (та же что в web)
SECRET_ENCRYPTION_KEY=__та_же_как_в_web__

# Верификация Telegram webhook (БАГ 52) — без неё worker не стартует в проде
TELEGRAM_WEBHOOK_SECRET=__сгенерить__

# Telegram bot
TELEGRAM_BOT_TOKEN=__из_BotFather__
TELEGRAM_BOT_USERNAME=YourBot

# Notifications
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Veloseller <noreply@your-domain.com>

# APScheduler
SCHEDULER_TIMEZONE=Europe/Warsaw
