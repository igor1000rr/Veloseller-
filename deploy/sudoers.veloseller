# Veloseller — sudoers для veloseller
# Полные права без пароля. Это безопасно потому что:
#   1. Сервер обслуживает только наше приложение
#   2. veloseller доступен только по SSH-ключу (PasswordAuthentication=no)
#   3. Один админ, GitHub Actions deploy под этим же юзером

veloseller ALL=(ALL) NOPASSWD: ALL
