# Veloseller — sudoers для деплоя
# СКОПИРОВАТЬ: sudo cp deploy/sudoers.veloseller /etc/sudoers.d/veloseller
# ПРОВЕРИТЬ: sudo visudo -cf /etc/sudoers.d/veloseller
#
# Это нужно чтобы GitHub Actions (пользователь veloseller) мог рестартить сервисы без пароля.

veloseller ALL=(root) NOPASSWD: /usr/bin/systemctl restart veloseller-web, /usr/bin/systemctl restart veloseller-worker, /usr/bin/systemctl status veloseller-web, /usr/bin/systemctl status veloseller-worker, /usr/bin/systemctl reload nginx
