# Veloseller web (.env.production) — СКОПИРОВАТЬ в /opt/veloseller/apps/web/.env.production
# И ЗАПОЛНИТЬ реальными значениями.

# Supabase (из supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://pptetnhdmxehijslbsrx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=__взять_из_Settings_API__
SUPABASE_SERVICE_ROLE_KEY=__секрет_не_выкладывать__

# Worker connection (локальный на том же сервере)
WORKER_URL=http://127.0.0.1:8001
WORKER_SECRET=__сгенерить__openssl_rand_base64_32__

# Encryption для marketplace tokens (та же что в worker)
SECRET_ENCRYPTION_KEY=__сгенерить__openssl_rand_base64_32__

# Resend (email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Veloseller <noreply@your-domain.com>

# Robokassa (платежи) — реквизиты из кабинета robokassa.ru → Технические настройки.
# БОЕВОЙ режим: задать MERCHANT_LOGIN + PASSWORD_1 + PASSWORD_2 (TEST_MODE НЕ ставить).
# ТЕСТ: ROBOKASSA_TEST_MODE=1 + TEST_PASSWORD_1/2 (боевые пароли тогда игнорируются).
# В кабинете Robokassa (алгоритм формирования подписи — MD5) прописать URL'ы:
#   Result URL  = https://veloseller.ru/api/robokassa/result   (Method: GET или POST)
#   Success URL = https://veloseller.ru/api/robokassa/success
#   Fail URL    = https://veloseller.ru/api/robokassa/fail
ROBOKASSA_MERCHANT_LOGIN=__логин_магазина__
ROBOKASSA_PASSWORD_1=__пароль_1_боевой__
ROBOKASSA_PASSWORD_2=__пароль_2_боевой__
# ROBOKASSA_TEST_MODE=1
# ROBOKASSA_TEST_PASSWORD_1=__тестовый_пароль_1__
# ROBOKASSA_TEST_PASSWORD_2=__тестовый_пароль_2__

# Admin
ADMIN_EMAILS=igor@your-domain.com
